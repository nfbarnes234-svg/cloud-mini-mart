# Environment variables for Cloud Mini Mart

# Required for API (Render/Railway)
DATABASE_URL=postgres://user:password@host:5432/minimart
SESSION_SECRET=replace_with_a_long_random_hex_string
NODE_ENV=production

# Optional
PORT=4000

# Frontend (Vercel)
API_BASE_URL=https://your-api-domain.example

# Notes
# - Replace placeholder values before deploying.
# - SESSION_SECRET must be the same across services that sign/verify JWTs.
# - DATABASE_URL should point to a Postgres instance accessible by the API.
